{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OpenAdOps Launch Pack",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "title", "executive_summary", "readiness", "assumptions", "media_plan", "campaigns", "creative_briefs", "measurement", "launch_checklist", "first_7_days", "open_questions", "risks"],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0" },
    "title": { "type": "string", "minLength": 1 },
    "executive_summary": { "type": "string", "minLength": 1 },
    "readiness": {
      "type": "object",
      "additionalProperties": false,
      "required": ["score", "status", "blockers"],
      "properties": {
        "score": { "type": "integer", "minimum": 0, "maximum": 100 },
        "status": { "enum": ["ready", "conditional", "blocked"] },
        "blockers": { "type": "array", "items": { "type": "string", "minLength": 1 } }
      }
    },
    "assumptions": { "$ref": "#/$defs/textArray" },
    "media_plan": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["platform", "role", "objective", "campaign_type", "allocation_percent", "budget_amount", "currency", "rationale", "prerequisites"],
        "properties": {
          "platform": { "type": "string", "minLength": 1 },
          "role": { "type": "string", "minLength": 1 },
          "objective": { "type": "string", "minLength": 1 },
          "campaign_type": { "type": "string", "minLength": 1 },
          "allocation_percent": { "type": ["number", "null"], "minimum": 0, "maximum": 100 },
          "budget_amount": { "type": ["number", "null"], "minimum": 0 },
          "currency": { "type": "string", "minLength": 1 },
          "rationale": { "type": "string", "minLength": 1 },
          "prerequisites": { "$ref": "#/$defs/textArrayAllowEmpty" }
        }
      }
    },
    "campaigns": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "platform", "campaign_name", "objective", "optimization_event", "geo", "bidding", "budget_note", "ad_group_logic", "audience_notes"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "platform": { "type": "string", "minLength": 1 },
          "campaign_name": { "type": "string", "minLength": 1 },
          "objective": { "type": "string", "minLength": 1 },
          "optimization_event": { "type": "string", "minLength": 1 },
          "geo": { "type": "string", "minLength": 1 },
          "bidding": { "type": "string", "minLength": 1 },
          "budget_note": { "type": "string", "minLength": 1 },
          "ad_group_logic": { "$ref": "#/$defs/textArray" },
          "audience_notes": { "$ref": "#/$defs/textArray" }
        }
      }
    },
    "creative_briefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "platform", "hypothesis", "angle", "hook", "format", "variants", "test_variable", "success_metric", "production_notes", "compliance_notes"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "platform": { "type": "string", "minLength": 1 },
          "hypothesis": { "type": "string", "minLength": 1 },
          "angle": { "type": "string", "minLength": 1 },
          "hook": { "type": "string", "minLength": 1 },
          "format": { "type": "string", "minLength": 1 },
          "variants": { "type": "integer", "minimum": 1, "maximum": 20 },
          "test_variable": { "type": "string", "minLength": 1 },
          "success_metric": { "type": "string", "minLength": 1 },
          "production_notes": { "$ref": "#/$defs/textArray" },
          "compliance_notes": { "$ref": "#/$defs/textArrayAllowEmpty" }
        }
      }
    },
    "measurement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_of_truth", "primary_event", "supporting_events", "platform_feedback", "attribution_rules", "tracking_checklist"],
      "properties": {
        "source_of_truth": { "type": "string", "minLength": 1 },
        "primary_event": { "type": "string", "minLength": 1 },
        "supporting_events": { "$ref": "#/$defs/textArray" },
        "platform_feedback": { "$ref": "#/$defs/textArray" },
        "attribution_rules": { "$ref": "#/$defs/textArray" },
        "tracking_checklist": { "$ref": "#/$defs/textArray" }
      }
    },
    "launch_checklist": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "category", "item", "status", "owner", "evidence"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "category": { "enum": ["strategy", "tracking", "campaign", "creative", "compliance", "operations"] },
          "item": { "type": "string", "minLength": 1 },
          "status": { "enum": ["ready", "needs_confirmation", "blocker"] },
          "owner": { "type": "string", "minLength": 1 },
          "evidence": { "type": "string", "minLength": 1 }
        }
      }
    },
    "first_7_days": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["period", "actions", "decision_rule"],
        "properties": {
          "period": { "type": "string", "minLength": 1 },
          "actions": { "$ref": "#/$defs/textArray" },
          "decision_rule": { "type": "string", "minLength": 1 }
        }
      }
    },
    "open_questions": { "$ref": "#/$defs/textArrayAllowEmpty" },
    "risks": { "$ref": "#/$defs/textArray" }
  },
  "$defs": {
    "textArray": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "textArrayAllowEmpty": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
